{
  "school_name": "Carleton University",
  "notes": [
    "First real config for the ingestion pipeline (cutover from legacy one-off scrapers).",
    "Scope is deliberately courses + library only: 'dates' stays curated in calendar_feed.py",
    "(shared with the ICS feed and frontend deadline tracker) and 'facts' stays curated in",
    "scrape_facts.py — both are hand-verified and better than what scraping would produce.",
    "Library URLs are the proven list from scrapers/active/scrape_library.py; the hours and",
    "study-room pages render their data via LibCal JavaScript widgets, so expect them to be",
    "thin until the LibCal source lands."
  ],
  "sources": [
    {
      "category": "courses",
      "url": "https://calendar.carleton.ca/undergrad/courses/",
      "extractor": "course_regex",
      "follow_links": true,
      "max_pages": 200,
      "min_records": 500
    },
    { "category": "library", "url": "https://library.carleton.ca/visit-building", "extractor": "llm_generic", "min_records": 10 },
